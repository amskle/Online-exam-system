# ============================================================
# Docker 部署环境变量
# ============================================================
# 复制此文件为 .env.docker，填入真实值后：
#   docker compose --env-file .env.docker up --build
# 注意：.env.docker 已被 .gitignore 忽略，不会提交到仓库

# ── MySQL ──
MYSQL_ROOT_PASSWORD=root123

# ── 数据库凭据（可选，默认 root / 空）──
DB_USERNAME=root
DB_PASSWORD=

# ── JWT 密钥（backend 和 ai-tutor 必须一致，生产环境请生成随机字符串）──
JWT_SECRET=t8Kx9mN2vB5qW3pL7sF4cH6jU1yR8eZ0aD5gJ9nM2xP4sV7wC3

# ── 邮件（QQ SMTP 授权码）──
MAIL_AUTH_CODE=your-mail-auth-code-here

# ── LLM API（DeepSeek）──
LLM_API_KEY=your-deepseek-api-key-here

# ── Embedding API（SiliconFlow / DeepSeek）──
EMBEDDING_API_KEY=your-embedding-api-key-here

# ========== 智能学习伙伴 (ai-tutor) 配置文件 ==========

# ── 服务 ──
APP_NAME=ai-tutor
APP_PORT=8080
DEBUG=true

# ── JWT（必须与 Spring Boot exam-backend 一致）──
JWT_SECRET=t8Kx9mN2vB5qW3pL7sF4cH6jU1yR8eZ0aD5gJ9nM2xP4sV7wC3
JWT_ALGORITHM=HS256

# ── 考试系统后端地址 ──
EXAM_BACKEND_URL=http://localhost:8077

# ── LLM API（国内模型，OpenAI-compatible）──
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-chat
# ── Embedding API（需单独配置，DeepSeek 不提供 embedding 服务）──
# 推荐 SiliconFlow（免费额度）或本地模型
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ── ChromaDB 向量存储 ──
VECTOR_DB_PATH=./chroma_store

# ── SQLite 会话存储 ──
SESSION_DB_PATH=./chat_sessions.db

# ── RAG 参数 ──
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=5

# ── Agent 参数 ──
LLM_TIMEOUT=60.0
GENERATE_BATCH_SIZE=5
GENERATE_MAX_ATTEMPTS=4
SESSION_HISTORY_LIMIT=12
SESSION_MAX_MESSAGES=50
